# Configuración del servidor
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Ruta base para despliegue en subcarpeta (dejar vacío si se accede directamente al puerto 3000)
# Si usas proxy inverso en Apache con /SOPORTEIT/, establece:
BASE_PATH=/SOPORTEIT

# Configuración de la base de datos MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=soporteit
DB_CONN_LIMIT=10

# Secreto para sesiones (cambiar en producción)
SESSION_SECRET=change_this_to_a_secure_random_string
