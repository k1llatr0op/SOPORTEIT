<header class="app-header d-flex justify-content-between align-items-center">
    <h1 class="title m-0">Sistema de Soporte IT</h1>
    <div class="d-flex gap-2 align-items-center">
        <a href="/logout" class="logout">Cerrar sesión</a>
    </div>
</header>

<div class="ticket-form">
    <div class="form-head">
        <h2>Nuevo <%= tipo %>
        </h2>
        <div class="form-head-right">
            <button type="button" id="btnEstado" class="btn-estado abierto" data-estado="ABIERTO">ABIERTO</button>
            <button type="submit" class="btn-brand" form="formTicket">Guardar</button>
            <a href="/menu" class="btn-beige">Cancelar</a>
        </div>
    </div>

    <form id="formTicket" action="/tickets/guardar" method="post" novalidate>
        <input type="hidden" id="estadoInput" name="estado" value="ABIERTO">
        <input type="hidden" name="tipo" value="<%= tipo %>">

        <!-- ===== Encabezado general ===== -->
        <div>
            <label>Área</label>
            <input type="text" name="area">
        </div>
        <div>
            <label>Departamento</label>
            <input type="text" name="departamento">
        </div>
        <div>
            <label>Fecha</label>
            <input type="date" name="fecha_ticket">
        </div>
        <div>
            <label>Ticket SN</label>
            <input type="text" name="ticket_sn" placeholder="Opcional">
        </div>

        <div>
            <label>Usuario (responsable del equipo)</label>
            <input type="text" name="usuario_resp">
        </div>
        <div>
            <label>Contacto</label>
            <input type="text" name="contacto_resp" placeholder="Tel / correo interno">
        </div>
        <div>
            <label>Responsable Interno</label>
            <input type="text" name="resp_interno" placeholder="Técnico o admin asignado">
        </div>
        <div>
            <label>Resumen (opcional)</label>
            <input type="text" name="resumen" placeholder="Descripción breve del caso">
        </div>

        <!-- ===== Datos del Equipo ===== -->
        <div class="grid-full">
            <h3 class="section-title">Datos del Equipo</h3>
        </div>

        <div>
            <label>Equipo</label>
            <input type="text" name="equipo" placeholder="Laptop, CPU, Monitor...">
        </div>
        <div>
            <label>Marca</label>
            <input type="text" name="marca">
        </div>
        <div>
            <label>Modelo</label>
            <input type="text" name="modelo">
        </div>
        <div>
            <label>S/N (Número de serie)</label>
            <input type="text" name="numeroserie">
        </div>
        <div>
            <label>Placa AF</label>
            <input type="text" name="placa_af" placeholder="Opcional">
        </div>

        <!-- ===== Garantía: datos específicos ===== -->
        <div class="grid-full">
            <h3 class="section-title">Datos de Garantía / Proveedor</h3>
        </div>

        <div>
            <label>Empresa proveedora</label>
            <input type="text" name="empresa_proveedora" placeholder="Proveedor o empresa que recibe el equipo">
        </div>
        <div>
            <label>Folio del ticket (proveedor)</label>
            <input type="text" name="folio_ticket" placeholder="Folio o referencia del proveedor">
        </div>
        <div>
            <label>Contacto del proveedor</label>
            <input type="text" name="contacto_proveedor" placeholder="Nombre y/o Tel/Correo">
        </div>

        <div class="grid-full">
            <label>Descripción de la falla</label>
            <textarea name="descripcion_falla" rows="3" placeholder="Detalles del problema reportado"></textarea>
        </div>

        <div>
            <label>Fecha de reporte a proveedor</label>
            <input type="date" name="fecha_reporte_proveedor">
        </div>
        <div>
            <label>Fecha de envío</label>
            <input type="date" name="fecha_envio">
        </div>
        <div>
            <label>Fecha de recepción</label>
            <input type="date" name="fecha_recepcion">
        </div>

        <div class="grid-full">
            <label>Resultado</label>
            <textarea name="resultado" rows="2" placeholder="Reparado, reemplazo, sin solución, etc."></textarea>
        </div>

        <div class="grid-full">
            <label>Observaciones</label>
            <textarea name="observaciones" rows="2" placeholder="Notas finales, números de guía, etc."></textarea>
        </div>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const btnEstado = document.getElementById("btnEstado");
        const inputEstado = document.getElementById("estadoInput");
        const estados = [
            { texto: "ABIERTO", clase: "abierto", valor: "ABIERTO" },
            { texto: "EN PROCESO", clase: "proceso", valor: "EN PROCESO" },
            { texto: "EN ESPERA", clase: "espera", valor: "EN ESPERA" },
            { texto: "CERRADO", clase: "cerrado", valor: "CERRADO" }
        ];
        let indice = 0;
        btnEstado.addEventListener("click", () => {
            indice = (indice + 1) % estados.length;
            const e = estados[indice];
            btnEstado.textContent = e.texto;
            btnEstado.className = `btn-estado ${e.clase}`;
            inputEstado.value = e.valor;
        });
    });
</script>

