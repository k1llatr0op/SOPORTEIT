            </h2>
            <div class="form-head-right">
                <!-- Botones movidos debajo del formulario -->
            </div>
        </div>

        <form id="formTicket" action="/tickets/<%= ticket.id_ticket %>/actualizar" method="post" enctype="multipart/form-data" novalidate>
