            <div class="grid-full">
                <h3 class="section-title">Datos específicos</h3>
            </div>

            <% if (ticket.tipo==='Diagnóstico' || ticket.tipo==='Mantenimiento' ) { %>
                <div>
                    <label>Usuario Windows</label>
                    <input type="text" name="usuario_windows" value="<%= hijo?.usuario_windows || '' %>" disabled>
                </div>
                <div>
                    <label>Contraseña</label>
                    <input type="text" name="contra_windows"
