            <div class="grid-full">
                <h3 class="section-title">Datos del Equipo</h3>
            </div>

            <div>
                <label>Equipo</label>
                <input type="text" name="equipo" value="<%= ticket.equipo %>" disabled>
            </div>
            <div>
                <label>Marca</label>
                <input type="text" name="marca" value="<%= ticket.marca %>" disabled>
            </div>
            <div>
                <label>Modelo</label>
                <input type="text" name="modelo" value="<%= ticket.modelo %>" disabled>
            </div>
            <div>
                <label>S/N</label>
