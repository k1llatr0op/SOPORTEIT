                            <% } else { %>
                                <div class="evidencia-sin-imagenes">No hay imágenes de evidencia adjuntas.</div>
                                <% } %>

                                    <!-- NUEVO: Input independiente para subir evidencias (se habilitará al editar el ticket) -->
                                    <div class="upload-evidencia-box mt-2">
                                        <input type="file" id="inputEvidencia" name="imagenes_evidencia"
