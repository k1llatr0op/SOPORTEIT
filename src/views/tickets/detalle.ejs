<% function _normEstado(e){ return String(e||'').trim().toUpperCase(); } function claseEstado(e='' ){ const
    s=_normEstado(e); if (s.includes('ABIERTO')) return 'abierto' ; if (s.includes('EN PROCESO')) return 'proceso' ; if
    (s.includes('EN ESPERA')) return 'espera' ; return 'cerrado' ; } function textoEstado(e='' ){ const
    s=_normEstado(e); if (s.includes('ABIERTO')) return 'ABIERTO' ; if (s.includes('EN PROCESO')) return 'EN PROCESO' ;
    if (s.includes('EN ESPERA')) return 'EN ESPERA' ; return 'CERRADO' ; }%>
    <header class="app-header d-flex justify-content-between align-items-center">
        <h1 class="title m-0">Sistema de Soporte IT</h1>
        <a href="/logout" class="logout">Cerrar sesión</a>
    </header>

    <div id="ticketFormRoot" class="ticket-form">
