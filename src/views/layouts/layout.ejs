<!doctype html>
<html lang="es">

<head>

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= (typeof title !=='undefined' && title) ? title : 'Sistema de Soporte IT' %>
  </title>


  <!-- fuente -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">

  <!-- Tu CSS compilado -->
  <link rel="stylesheet" href="/css/main.css?v=20251104">
</head>

<body class="bg-app text-body" data-is-admin="<%= (typeof isAdmin !== 'undefined' && isAdmin) ? '1' : '0' %>"
  style="font-family:'Poppins',system-ui,-apple-system,Segoe UI,Roboto;">


  <main class="container py-4">
    <% if (usuario) { %>
    <% } %>

    <%- body %>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
    crossorigin="anonymous"></script>

  <!-- 🔹 Toast global -->
  <div id="toast" class="toast hidden" aria-live="polite" aria-atomic="true"></div>
  <script>
    function showToast(mensaje, duracion = 3000, tipo = 'success') {
      const toast = document.getElementById('toast');
      if (!toast) return;
      toast.textContent = mensaje;
      toast.className = `toast ${tipo}`;
      toast.classList.remove('hidden');
      // pequeño delay para que la transición entre
      setTimeout(() => toast.classList.add('show'), 10);
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, duracion);
    }

    (function () {
      const url = new URL(window.location.href);
      const val = url.searchParams.get('toast');
      if (!val) return;

      const map = {
        creado: 'Ticket creado correctamente',
        guardado: 'Cambios guardados con éxito',
        estado: 'Estado actualizado',
        eliminado: 'Ticket eliminado correctamente',
        nota_creada: 'Nota agregada',
        nota_vacia: 'Debes escribir una nota',
        error: 'Ocurrió un error, intenta de nuevo'
      };

      // tipo visual (éxito/error)
      const tipo = (val === 'error' || val === 'nota_vacia') ? 'error' : 'success';
      showToast(map[val] || 'Operación realizada', 3000, tipo);

      // limpiar el query param sin recargar
      url.searchParams.delete('toast');
      window.history.replaceState({}, '', url.toString());
    })();
  </script>

</body>

</html>