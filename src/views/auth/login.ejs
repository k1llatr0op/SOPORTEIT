<div class="login-split">
  <div class="login-left">
    <div class="login-left-content">
    <img src="/img/logo.png" alt="Logo" style="width:120px; display:block; margin:0 auto;">
      <h1 class="login-system-title">Sistema de Soporte IT</h1>
      <p class="login-system-sub">Gestión de tickets y soporte técnico</p>
    </div>
  </div>

  <div class="login-right">
    <div class="login-form-wrap">
      <h2 class="login-title">Iniciar sesión</h2>
      <p class="login-subtitle">Acceso Administrativo</p>

      <form method="post" action="/login">
        <div class="mb-3">
          <label for="user" class="form-label small text-muted">Usuario</label>
          <input id="user" name="usuario" type="text"
            class="form-control form-control-lg"
            placeholder="Usuario"
            value="<%= lastUser || '' %>"
            required>
        </div>
        <div class="mb-4">
          <label for="pwd" class="form-label small text-muted">Contraseña</label>
          <input id="pwd" name="contra" type="password"
            class="form-control form-control-lg"
            placeholder="••••••••" required>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger py-2" role="alert"><%= error %></div>
        <% } %>

        <div class="d-grid">
          <button class="btn btn-brand btn-lg" type="submit">Iniciar Sesión</button>
        </div>

        <div class="text-center">
          <a href="/forgot-password" class="forgot-link">¿Olvidaste tu contraseña?</a>
        </div>
      </form>
    </div>
  </div>
</div>