<div class="login-split">
  <div class="login-left">
    <div class="login-left-content">
      <img src="/img/logo.png" alt="Logo" style="width:200px;">
      <h1 class="login-system-title">Sistema de Soporte IT</h1>
      <p class="login-system-sub">Recupera el acceso con tu correo o número de celular registrado</p>
    </div>
  </div>

  <div class="login-right">
    <div class="login-form-wrap">
      <h2 class="login-title">Recuperar contraseña</h2>
      <p class="login-subtitle">Te enviaremos un enlace para restablecerla</p>

      <% if (error) { %>
        <div class="alert alert-danger py-2" role="alert"><%= error %></div>
      <% } %>
      <% if (message) { %>
        <div class="alert alert-success py-2" role="status"><%= message %></div>
      <% } %>

      <form method="post" action="/forgot-password">
        <div class="mb-4">
          <label for="contacto" class="form-label small text-muted">Correo o celular</label>
          <input id="contacto" name="contacto" type="text"
            class="form-control form-control-lg"
            placeholder="correo@dominio.com o 5512345678"
            value="<%= typeof contacto !== 'undefined' ? contacto : '' %>"
            required>
        </div>

        <div class="d-grid">
          <button class="btn btn-brand btn-lg" type="submit">Enviar enlace</button>
        </div>

        <div class="text-center" style="margin-top: 1rem;">
          <a href="/login" class="forgot-link">Volver al inicio de sesión</a>
        </div>
      </form>
    </div>
  </div>
</div>
